@using Spotify.Dto.Album
@using Spotify.Model

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f5f5f5;
        margin: 0;
        padding: 20px;
    }

    .album-container {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }

    .album-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        width: 250px;
        text-align: center;
    }

        .album-card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

    .album-info {
        padding: 15px;
    }

    .album-title {
        font-size: 18px;
        font-weight: bold;
        margin: 10px 0;
    }

    .album-artist {
        font-size: 14px;
        color: #666;
    }

    .album-date {
        font-size: 12px;
        color: #999;
        margin-top: 5px;
    }
</style>

@model List<GetAllAlbumDto>
<div class="album-container">
    @foreach (var album in Model)
    {
        <div class="album-card">
            <a asp-Controller="Album" asp-action="Details" asp-route-id="@album.Id" >
                <img src="https://avatars.mds.yandex.net/i?id=5d75749d19315f074350dff66d558154_l-5220825-images-thumbs&n=13">
                <div class="album-info">
                    <div class="album-title">@album.Title</div>
                </div>
            </a>
        </div>
    }
</div>